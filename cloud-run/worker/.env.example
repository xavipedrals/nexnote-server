SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
WORKER_SHARED_SECRET=generate-a-random-32-byte-hex
OPENAI_API_KEY=sk-...
XAI_API_KEY=xai-...
# Grok TTS voice IDs: eve, ara, rex, sal, leo
XAI_VOICE_HOST_A=rex
XAI_VOICE_HOST_B=eve
GEMINI_API_KEY=...
PORT=8080

